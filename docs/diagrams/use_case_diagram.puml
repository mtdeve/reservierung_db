@startuml UseCaseDiagram
left to right direction

skinparam linetype ortho
skinparam shadowing false
skinparam packageStyle rectangle

actor Teilnehmer
actor Mitarbeiter
actor Administrator

rectangle "Reservierungssystem" {

  usecase "Verfügbarkeit prüfen" as UC1
  usecase "Gerät reservieren" as UC2
  usecase "Reservierungen einsehen" as UC3
  usecase "Reservierung stornieren / ändern" as UC4

  usecase "Reservierungen verwalten" as UC5
  usecase "Gerätezustand ändern" as UC6
  usecase "Geräte verwalten" as UC7
  usecase "Preise verwalten" as UC8
  usecase "Kundendaten einsehen" as UC9

  usecase "Audit-Protokoll einsehen" as UC10
  usecase "Datenbankzugriffe verwalten" as UC11
  usecase "System administrieren" as UC12
}

Teilnehmer -- UC2
Teilnehmer -- UC3

UC2 ..> UC1 : <<include>>
UC4 ..> UC3 : <<extend>>

Mitarbeiter -- UC5
Mitarbeiter -- UC6
Mitarbeiter -- UC7
Mitarbeiter -- UC8
Mitarbeiter -- UC9

Administrator -- UC10
Administrator -- UC11
Administrator -- UC12

Teilnehmer --> Mitarbeiter
Mitarbeiter --> Administrator

note left of UC3
Teilnehmer -> nur eigene Reservierungen.
Mitarbeiter -> sieht alle Reservierungen.
end note

@enduml
